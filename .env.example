## Base API URL (no trailing slash required). If it does NOT end with /test, /test is added for orders-by-date.
BASE_URL=https://admin.amarpet.com/api/v1

## API key sent as X-API-Key (override name with API_KEY_HEADER).
API_KEYS=your-api-key

## Optional: if you use client allowlists in a future server version
# MCP_CLIENT_API_KEY=your-api-key
